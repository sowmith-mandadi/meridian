# ─── OpenAI (required) ───
OPENAI_API_KEY=sk-...

# ─── Database ───
# Local development:
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Vercel / Production (uncomment and fill):
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=eyJhb...

# ─── Auth ───
# Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-random-string

# Not needed on Vercel (auto-detected via trustHost: true)
# AUTH_URL=http://localhost:3000
