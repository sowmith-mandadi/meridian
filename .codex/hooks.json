{
  "hooks": [
    {
      "event": "pre-commit",
      "description": "Run typecheck and lint before committing",
      "command": "pnpm typecheck && pnpm lint",
      "fail_on_error": true
    },
    {
      "event": "post-task",
      "description": "Verify build still passes after task completion",
      "command": "pnpm typecheck",
      "fail_on_error": false
    },
    {
      "event": "pre-push",
      "description": "Full build check before pushing",
      "command": "pnpm build",
      "fail_on_error": true
    }
  ]
}
