{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "npx tsx scripts/seed.ts",
    "db:push:prod": "dotenv -e .env.production -- drizzle-kit push",
    "db:seed:prod": "dotenv -e .env.production -- npx tsx scripts/seed.ts",
    "mcp:build": "esbuild ./plugins/meridian-healthcare/mcp-server.ts --bundle --platform=node --format=esm --outfile=./plugins/meridian-healthcare/mcp-server.mjs --packages=external",
    "mcp:serve": "npx tsx plugins/meridian-healthcare/mcp-http-server.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/react": "^3.0.160",
    "@libsql/client": "^0.17.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.158",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "mcp-handler": "^1.1.0",
    "next": "16.2.3",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
