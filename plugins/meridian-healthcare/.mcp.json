{
  "servers": {
    "meridian": {
      "command": "npx",
      "args": ["tsx", "./plugins/meridian-healthcare/mcp-server.ts"],
      "env": {
        "TURSO_DATABASE_URL": "${TURSO_DATABASE_URL}",
        "TURSO_AUTH_TOKEN": "${TURSO_AUTH_TOKEN}",
        "MERIDIAN_API_URL": "${MERIDIAN_API_URL}"
      },
      "description": "Meridian Healthcare Intelligence — 7 tools for cohort queries, risk analysis, outreach, charts, pipeline execution"
    }
  }
}
